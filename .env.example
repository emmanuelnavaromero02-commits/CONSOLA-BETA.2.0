# MODecissions local environment example.
# Copy to infra/.env and replace every CHANGEME value before starting services.

INTERNAL_API_KEY=CHANGEME_generate_32_plus_random_chars
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8001

# Console JWT access tokens
JWT_SECRET_KEY=CHANGEME_generate_64_plus_random_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Database
POSTGRES_PASSWORD=CHANGEME_generate_strong_postgres_password
PG_DSN=host=localhost port=5432 dbname=modecissions user=postgres password=CHANGEME_generate_strong_postgres_password

# MinIO / lakehouse
MINIO_ROOT_PASSWORD=CHANGEME_generate_strong_minio_secret_key
MINIO_SECRET_KEY=CHANGEME_generate_strong_minio_secret_key

# LLM providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
CHAT_LLM_PROVIDER=gemini
CHAT_LLM_MODEL=gemini-1.5-flash
SQL_LLM_MODEL=claude-sonnet-4-6
GEMINI_CACHE_ENABLED=true

# Replicon
REPLICON_BASE_URL=https://na5.replicon.com/analytics
REPLICON_TOKEN=
REPLICON_USE_DEMO=false

# Public URLs
CONSOLE_URL=http://localhost:8000
WORKSPACE_PUBLIC_URL=http://localhost:8001

# Superset
SUPERSET_SECRET_KEY=CHANGEME_generate_64_hex_chars
SUPERSET_ADMIN_USER=CHANGEME_superset_admin_user
SUPERSET_ADMIN_PASSWORD=CHANGEME_generate_strong_superset_password

# Airflow
AIRFLOW_SECRET_KEY=CHANGEME_generate_64_hex_chars
AIRFLOW_ADMIN_USER=CHANGEME_airflow_admin_user
AIRFLOW_ADMIN_PASSWORD=CHANGEME_generate_strong_airflow_password

# SMTP
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@modecissions.local
SMTP_USE_TLS=false

# Token TTLs
INVITE_TOKEN_TTL_HOURS=72
RESET_TOKEN_TTL_HOURS=1

# AWS-only values, unused for local Docker unless explicitly configured
AWS_REGION=us-east-1
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
