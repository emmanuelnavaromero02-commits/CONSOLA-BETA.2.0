# MODecissions AWS deploy environment example.
# Copy to .env on the EC2 app host and replace every CHANGEME value.

# Postgres containers on EC2 App
POSTGRES_PASSWORD=CHANGEME_generate_strong_postgres_password

# Internal service authentication
INTERNAL_API_KEY=CHANGEME_generate_32_plus_random_chars
ALLOWED_ORIGINS=http://10.0.2.X:8000,http://10.0.2.X:8001

# Console JWT access tokens
JWT_SECRET_KEY=CHANGEME_generate_64_plus_random_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Terraform outputs / AWS
S3_BUCKET_NAME=CHANGEME_terraform_output_s3_bucket_name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGEME_airflow_s3_access_key_id
AWS_SECRET_ACCESS_KEY=CHANGEME_airflow_s3_secret_access_key

# Public URLs visible through VPN
CONSOLE_URL=http://10.0.2.X:8000
WORKSPACE_PUBLIC_URL=http://10.0.2.X:8001

# LLM config
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
CHAT_LLM_PROVIDER=anthropic
CHAT_LLM_MODEL=claude-haiku-4-5-20251001
SQL_LLM_MODEL=claude-sonnet-4-6
GEMINI_CACHE_ENABLED=true

# Embeddings / RAG
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# Superset
SUPERSET_SECRET_KEY=CHANGEME_generate_64_hex_chars
SUPERSET_ADMIN_USER=CHANGEME_superset_admin_user
SUPERSET_ADMIN_PASSWORD=CHANGEME_generate_strong_superset_password

# Airflow
AIRFLOW_SECRET_KEY=CHANGEME_generate_64_hex_chars
AIRFLOW_ADMIN_USER=CHANGEME_airflow_admin_user
AIRFLOW_ADMIN_PASSWORD=CHANGEME_generate_strong_airflow_password

# Email / SMTP
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@modecissions.local
SMTP_USE_TLS=false

# Token TTLs
INVITE_TOKEN_TTL_HOURS=72
RESET_TOKEN_TTL_HOURS=1
